lambda +
0.5 * x1 +
0.3 * x2 +
trend_x +
treatment_effect +
epsilon
)
# ------------------------------------------------------------
# Vista rápida
# ------------------------------------------------------------
df %>% glimpse()
# Define años
treat_year <- 2020
base_year  <- treat_year - 1
# Mantener solo unidades tratadas o nunca tratadas
# En diseño no escalonado: todos los tratados empiezan en treat_year
df_did <- df %>%
mutate(
G = if_else(treated == 1, treat_year, 0),
rel_time = year - treat_year
)
att_ipw <- att_gt(
yname = "y",
tname = "year",
idname = "id",
gname = "G",
xformla = ~ x1 + x2,
data = df_did,
panel = TRUE,
control_group = "nevertreated",
est_method = "ipw",
base_period = "universal"
)
dyn_ipw_attgt <- aggte(att_ipw, type = "dynamic")
# Tabla dinámica de att_gt()
tab_attgt <- tibble(
rel_time = dyn_ipw_attgt$egt,
att_attgt = dyn_ipw_attgt$att.egt,
se_attgt = dyn_ipw_attgt$se.egt,
ci_low_attgt = att_attgt - 1.96 * se_attgt,
ci_high_attgt = att_attgt + 1.96 * se_attgt
)
tab_attgt
years_to_compare <- sort(unique(df_did$year))
years_to_compare <- years_to_compare[years_to_compare != base_year]
tab_drdid <- map_dfr(years_to_compare, function(tt) {
df_pair <- df_did %>%
filter(year %in% c(base_year, tt)) %>%
mutate(
post = as.integer(year == tt),
rel_time = tt - treat_year
)
est <- ipwdid(
yname = "y",
tname = "post",
idname = "id",
dname = "treated",
xformla = ~ x1 + x2,
data = df_pair,
panel = TRUE
)
tibble(
year = tt,
rel_time = tt - treat_year,
att_drdid = est$ATT,
se_drdid = est$se,
ci_low_drdid = att_drdid - 1.96 * se_drdid,
ci_high_drdid = att_drdid + 1.96 * se_drdid
)
})
tab_drdid
comparison <- tab_attgt %>%
left_join(tab_drdid, by = "rel_time") %>%
mutate(
diff_att = att_attgt - att_drdid,
ratio_se = se_attgt / se_drdid
)
comparison
library(modelsummary)
datasummary_df(
comparison,
output = "html"
)
plot_df <- comparison %>%
select(
rel_time,
att_attgt, ci_low_attgt, ci_high_attgt,
att_drdid, ci_low_drdid, ci_high_drdid
) %>%
tidyr::pivot_longer(
cols = -rel_time,
names_to = "name",
values_to = "value"
) %>%
tidyr::separate(name, into = c("stat", "method"), sep = "_", extra = "merge") %>%
tidyr::pivot_wider(
names_from = stat,
values_from = value
) %>%
mutate(
method = recode(
method,
"attgt" = "did::att_gt IPW",
"drdid" = "DRDID::ipwdid"
)
)
ggplot(plot_df, aes(x = rel_time, y = att, color = method)) +
geom_hline(yintercept = 0, linetype = "dashed") +
geom_vline(xintercept = -1, linetype = "dotted") +
geom_point(position = position_dodge(width = 0.25)) +
geom_errorbar(
aes(ymin = ci_low, ymax = ci_high),
width = 0.15,
position = position_dodge(width = 0.25)
) +
geom_line(position = position_dodge(width = 0.25)) +
labs(
title = "Event study: IPW con did::att_gt vs DRDID::ipwdid",
x = "Tiempo relativo al tratamiento",
y = "ATT",
color = "Método"
) +
theme_minimal()
